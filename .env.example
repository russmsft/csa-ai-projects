# Copy this to .env and fill in your values
# Never commit .env to git

# Azure OpenAI / Foundry endpoint
# Format: https://<account-name>.cognitiveservices.azure.com/
# Find it in Azure Portal: Cognitive Services resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<account-name>.cognitiveservices.azure.com/

# Service Bus namespace host (only needed for Project 03 — Email Triage Agent)
# Format: <namespace>.servicebus.windows.net  (Entra ID auth — no connection string)
# SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net
